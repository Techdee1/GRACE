# Required — obtain from https://console.groq.com/keys
GROQ_API_KEY=your_groq_api_key_here

# Postgres connection (matches docker-compose defaults)
POSTGRES_URL=postgresql+psycopg://grace:grace@postgres:5432/grace

# Neo4j connection (matches docker-compose defaults)
NEO4J_URI=bolt://neo4j:7687
NEO4J_USER=neo4j
NEO4J_PASSWORD=grace_password

# Redis connection (matches docker-compose defaults)
REDIS_URL=redis://redis:6379/0

# Groq model (do not change for Phase 1)
GROQ_MODEL=llama-3.3-70b-versatile

# Lua agent webhook bridge (backend -> Lua transaction-intake webhook)
# 1) Ensure webhook is deployed/active:
#    cd agent
#    npx lua webhooks deploy --webhook-name transaction-intake --webhook-version latest
#    npx lua webhooks activate --webhook-name transaction-intake
#
# 2) Get webhook endpoint URL from the Lua dashboard (CLI shows ID/version, not endpoint URL).
#    Keep this value in sync with the production transaction-intake webhook endpoint.
LUA_TRANSACTION_INTAKE_WEBHOOK_URL=
#
# 3) Set Lua-side auth key used by the webhook:
#    cd agent
#    npx lua env production --key INTAKE_WEBHOOK_KEY --value <shared-secret>
#
# 4) Set the same shared secret here so backend can send x-intake-key.
LUA_TRANSACTION_INTAKE_KEY=
LUA_TRANSACTION_INTAKE_TIMEOUT_SECONDS=30
